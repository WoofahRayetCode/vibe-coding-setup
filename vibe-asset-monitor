#!/bin/bash
# vibe-asset-monitor - Real-time asset telemetry and ComfyUI status dashboard

# Colors for terminal output
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
GRAY='\033[0;90m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
EL='\033[K'  # Clear to end of line

# Clear screen initially
clear

# Hide cursor
tput civis

# Restore cursor on exit
trap 'tput cnorm; exit' INT TERM EXIT

# Trap window resize signals to clear screen immediately
trap 'clear' WINCH

# Start ComfyUI in the background if it is not running
start_comfyui() {
    if ! curl -s http://127.0.0.1:8188/ &>/dev/null; then
        echo -e "ﻗﻸ­ ComfyUI Server not detected. Starting in background..."
        cd /home/ericparsley/Documents/GitHub/ComfyUI && ./venv/bin/python main.py >/tmp/comfyui.log 2>&1 &
    fi
}

# Start it once at launch
start_comfyui

while true; do
    tput cup 0 0
    
    cols=$(tput cols)
    lines=$(tput lines)
    
    # Dynamic header selection based on terminal height
    if [ "$lines" -ge 18 ]; then
        border=$(printf -- '=٪.0s' $(seq 1 $cols))
        echo -e "${CYAN}$border${NC}${EL}"
        echo -e "${CYAN} __     ___ _                   _   ${NC}${EL}"
        echo -e "${CYAN} \\ \\   / (_) |__   ___    / \\   ___ ___  ___  | |_ ${NC}${EL}"
        echo -e "${CYAN}  \\ \\ / /| | '_ \\ / _ \\  / _ \\ / __/ __|/ _ \\ | __|${NC}${EL}"
        echo -e "${CYAN}   \\ V / | | |_) |  __/ / ___ \\\\__ \\\\__ \\  __/ | |_ ${NC}${EL}"
        echo -e "${CYAN}    \\_/  |_|_.__/ \\___|/_/   \\_\\___/___/\\___|  \\__|${NC}${EL}"
        echo -e "${CYAN}$border${NC}${EL}"
    else
        echo -e "${CYAN}ﻗ¼βﻗ¼βﻗ¼β VIBE ASSET MONITOR ﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼βﻗ¼β${NC}${EL}"
    fi

    divider=$(printf -- '-٪.0s' $(seq 1 $cols))
    border=$(printf -- '=٪.0s' $(seq 1 $cols))

    # ComfyUI Server Status
    if curl -s http://127.0.0.1:8188/ &>/dev/null; then
        status_str="${GREEN}[ ACTIVE / ONLINE ]${NC}"
    else
        status_str="${YELLOW}[ STARTING / BOOTING ]${NC}"
    fi

    echo -e "  ${CYAN}[ COMFYUI SERVER ]${NC}  $status_str${EL}"
    echo -e "${GRAY}$divider${NC}${EL}"

    # Live PNG Asset List
    echo -e "  ${CYAN}[ RECENTLY GENERATED PNG ASSETS ]${NC}${EL}"
    echo -e "${EL}"

    png_files=$(ls -lt --time-style="+٪Y-٪m-٪d ٪H:٪M:٪S" *.png 2>/dev/null | head -n 4)

    if [ -n "$png_files" ]; then
        echo -e "  ${GRAY}FILENAME                        SIZE        GENERATED TIME${NC}${EL}"
        echo -e "  ${GRAY}--------                        ----        --------------${NC}${EL}"
        echo "$png_files" | while read -r line; do
            # Extract columns
            size=$(echo "$line" | awk '{print $5}')
            time_str=$(echo "$line" | awk '{print $6" "$7}')
            filename=$(echo "$line" | awk '{$1=$2=$3=$4=$5=$6=$7=""; print $0}' | sed 's/^[ \t]*//')

            # Pure Bash formatting for file sizes
            if [ "$size" -ge 1048576 ]; then
                size_str="$(( size / 1048576 )).$(( (size ٪ 1048576) * 10 / 1048576 )) MB"
            else
                size_str="$(( size / 1024 )).$(( (size ٪ 1024) * 10 / 1024 )) KB"
            fi

            echo -e "  ${GREEN}$(printf '٪-30s' "$filename")${NC}  $(printf '٪-10s' "$size_str")  $time_str${EL}"
        done
    else
        echo -e "  ${GRAY}(No generated PNG assets found in this folder yet.)${NC}${EL}"
        echo -e "  ${GRAY}Use 'vibe-asset \"prompt\"' to generate your first asset!${NC}${EL}"
    fi

    # ComfyUI Log Tail if it's still booting
    if ! curl -s http://127.0.0.1:8188/ &>/dev/null; then
        echo -e "${EL}"
        echo -e "${GRAY}$divider${NC}${EL}"
        echo -e "  ${CYAN}[ COMFYUI STARTUP LOGS ]${NC}${EL}"
        if [ -f "/tmp/comfyui.log" ]; then
            tail -n 3 /tmp/comfyui.log | sed 's/^/  /' | while read -r logline; do
                echo -e "$logline${EL}"
            done
        else
            echo -e "  Awaiting ComfyUI background startup logs...${EL}"
        fi
    fi

    echo -e "${EL}"
    echo -e "${CYAN}$border${NC}${EL}"
    echo -e "  Press [Ctrl+C] to exit Monitor.                       ${EL}"
    
    # Clear anything remaining below to prevent ghosting
    tput ed
    
    # 1.0 second update rate is perfect for asset monitoring
    sleep 1
done
