#!/bin/bash
# vibe-commands - High-density static cheatsheet designed for compact terminal panes

# Colors for terminal output
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
GRAY='\033[0;90m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m' # No Color
EL='\033[K'  # Clear to end of line

# Clear screen initially
clear

# Hide cursor
tput civis

# Restore cursor on exit
trap 'tput cnorm; exit' INT TERM EXIT

# Trap window resize signals to force a redraw
trap 'clear; draw_cheatsheet' WINCH

draw_cheatsheet() {
    tput cup 0 0
    echo -e "${CYAN}═══ VIBE CUSTOM COMMANDS ═══════════════════════════${NC}${EL}"
    echo -e "  ${GREEN}vibe-start [dir] [mode] [prof]${NC}   Start Tmux session${EL}"
    echo -e "  ${GREEN}vibe-switch [mode] [prof]${NC}        Hot-swap active session${EL}"
    echo -e "    ${GRAY}Modes:${NC} qwen, deepseek, translate, uncensored${EL}"
    echo -e "    ${GRAY}Profiles:${NC} gamedev, general${EL}"
    echo -e "  ${GREEN}vibe-translate <src> <tgt>${NC}       File translation${EL}"
    echo -e "  ${GREEN}vibe-asset <prompt>${NC}               Generate sprites${EL}"
    echo -e "  ${GREEN}vibe-free${NC}                         Free GPU VRAM${EL}"
    
    echo -e "${YELLOW}═══ AIDER CO-PILOT COMMANDS ════════════════════════${NC}${EL}"
    echo -e "  ${CYAN}/add <file>${NC}   Add context        ${CYAN}/undo${NC}   Revert last${EL}"
    echo -e "  ${CYAN}/drop <file>${NC}  Drop context       ${CYAN}/diff${NC}   Show changes${EL}"
    echo -e "  ${CYAN}/ask <query>${NC}  Ask codebase       ${CYAN}/exit${NC}   Close Aider${EL}"
    
    echo -e "${MAGENTA}═══ PROMPT & MODEL COMBINATIONS ════════════════════${NC}${EL}"
    echo -e "  ${GREEN}vibe-start . gamedev${NC}         Qwen + Game Dev Prompt${EL}"
    echo -e "  ${GREEN}vibe-start . deepseek general${NC}  DeepSeek + General Dev${EL}"
    echo -e "  ${GREEN}vibe-start . translate gamedev${NC} Translator + Game Dev${EL}"
    
    # Fill remaining space to prevent ghosting
    current_lines=$(tput lines)
    for ((i=17; i<current_lines; i++)); do
        echo -e "${EL}"
    done
}

# Initial draw
draw_cheatsheet

# Keep script alive without consuming CPU
while true; do
    sleep 60
done
