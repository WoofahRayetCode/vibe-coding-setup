#!/bin/bash

# Colors for terminal output
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
GRAY='\033[0;90m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
EL='\033[K'  # Clear to end of line

# Clear screen initially
clear

# Hide cursor
tput civis

# Flag to track if the static ASCII header has been drawn
header_drawn=0

# Variables for pure Bash CPU calculation
prev_idle=0
prev_total=0

# Variables for pure Bash Disk I/O calculation
prev_read_sectors=0
prev_write_sectors=0

# Restore cursor on exit
trap 'tput cnorm; exit' INT TERM EXIT

# Trap window resize signals to force a clear
trap 'clear' WINCH

draw_header() {
    cols=$(tput cols)
    border=$(printf -- '=%.0s' $(seq 1 $cols))
    echo -e "${CYAN}$border${NC}${EL}"
    echo -e "${CYAN} __     ___ _            _   _ _   _ ____   ${NC}${EL}"
    echo -e "${CYAN} \\ \\   / (_) |__   ___  | | | | | | |  _ \\  ${NC}${EL}"
    echo -e "${CYAN}  \\ \\ / /| | '_ \\ / _ \\ | |_| | | | | | | | ${NC}${EL}"
    echo -e "${CYAN}   \\ V / | | |_) |  __/ |  _  | |_| | |_| | ${NC}${EL}"
    echo -e "${CYAN}    \\_/  |_|_.__/ \\___| |_| |_|\\___/|____/  ${NC}${EL}"
    echo -e "${CYAN}$border${NC}${EL}"
}

while true; do
    # 1. Reset cursor to top-left to redraw cleanly without scrolling
    tput cup 0 0
    draw_header

    # Fetch terminal dimensions
    cols=$(tput cols)
    lines=$(tput lines)
    divider=$(printf -- '-%.0s' $(seq 1 $cols))
    border=$(printf -- '=%.0s' $(seq 1 $cols))

    # Fetch active models
    models_output=$(ollama ps 2>/dev/null | tail -n +2)

    # 2. Print Dynamic Info (Time & Shell)
    current_time=$(date +"%Y-%m-%d %H:%M:%S")
    echo -e "  ${CYAN}[ SYSTEM TIME ]${NC}  $current_time${EL}"
    echo -e "  ${CYAN}[ HOST SHELL  ]${NC}  $SHELL${EL}"
    echo -e "  ${CYAN}[ WORKING DIR ]${NC}  $(pwd)${EL}"
    echo -e "${GRAY}$divider${NC}${EL}"
    echo -e "${EL}"

    # 4. Fetch and Print Live Hardware Telemetry
    # A. NVIDIA GPU & VRAM Status
    gpu_info=$(nvidia-smi --query-gpu=memory.used,memory.total,utilization.gpu,temperature.gpu --format=csv,noheader,nounits 2>/dev/null)
    if [ -n "$gpu_info" ]; then
        gpu_used=$(echo "$gpu_info" | awk -F', ' '{print $1}')
        gpu_total=$(echo "$gpu_info" | awk -F', ' '{print $2}')
        gpu_load=$(echo "$gpu_info" | awk -F', ' '{print $3}')
        gpu_temp=$(echo "$gpu_info" | awk -F', ' '{print $4}')

        # Floating point calculations in pure Bash
        used_gb_val=$(( gpu_used / 1024 ))
        used_mb_val=$(( (gpu_used % 1024) * 10 / 1024 ))
        gpu_used_gb="${used_gb_val}.${used_mb_val}"

        total_gb_val=$(( gpu_total / 1024 ))
        total_mb_val=$(( (gpu_total % 1024) * 10 / 1024 ))
        gpu_total_gb="${total_gb_val}.${total_mb_val}"

        gpu_pct=$(( gpu_used * 100 / gpu_total ))

        # Create VRAM Progress Bar
        bar_width=12
        filled=$(( gpu_pct * bar_width / 100 ))
        empty=$(( bar_width - filled ))
        
        if [ "$filled" -gt 0 ]; then
            bar_filled=$(printf -- '█%.0s' $(seq 1 $filled))
        else
            bar_filled=""
        fi
        if [ "$empty" -gt 0 ]; then
            bar_empty=$(printf -- '░%.0s' $(seq 1 $empty))
        else
            bar_empty=""
        fi

        # Create GPU Load Progress Bar
        gpu_load_filled=$(( gpu_load * bar_width / 100 ))
        gpu_load_empty=$(( bar_width - gpu_load_filled ))

        if [ "$gpu_load_filled" -gt 0 ]; then
            gpu_load_bar_filled=$(printf -- '█%.0s' $(seq 1 $gpu_load_filled))
        else
            gpu_load_bar_filled=""
        fi
        if [ "$gpu_load_empty" -gt 0 ]; then
            gpu_load_bar_empty=$(printf -- '░%.0s' $(seq 1 $gpu_load_empty))
        else
            gpu_load_bar_empty=""
        fi
    else
        gpu_used_gb="N/A"
        gpu_total_gb="N/A"
        gpu_pct=0
        gpu_load="N/A"
        gpu_temp="N/A"
        bar_filled=""
        bar_empty="░░░░░░░░░░░░"
        gpu_load_bar_filled=""
        gpu_load_bar_empty="░░░░░░░░░░░░"
    fi

    # B. Pure Bash CPU Utilization Calculator (reads ticks since last 0.2s loop)
    read -r _ user nice system idle iowait irq softirq steal guest guest_nice < /proc/stat
    total_ticks=$((user + nice + system + idle + iowait + irq + softirq + steal))
    idle_ticks=$idle

    diff_total=$((total_ticks - prev_total))
    diff_idle=$((idle_ticks - prev_idle))

    if [ "$diff_total" -gt 0 ]; then
        cpu_usage=$(( (diff_total - diff_idle) * 100 / diff_total ))
    else
        cpu_usage=0
    fi

    prev_total=$total_ticks
    prev_idle=$idle_ticks

    # Create CPU Progress Bar
    cpu_bar_width=12
    cpu_filled=$(( cpu_usage * cpu_bar_width / 100 ))
    cpu_empty=$(( cpu_bar_width - cpu_filled ))
    
    if [ "$cpu_filled" -gt 0 ]; then
        cpu_bar_filled=$(printf -- '█%.0s' $(seq 1 $cpu_filled))
    else
        cpu_bar_filled=""
    fi
    if [ "$cpu_empty" -gt 0 ]; then
        cpu_bar_empty=$(printf -- '░%.0s' $(seq 1 $cpu_empty))
    else
        cpu_bar_empty=""
    fi

    # Fetch CPU temperature dynamically from /sys/class/thermal
    cpu_temp_raw=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null)
    if [ -z "$cpu_temp_raw" ]; then
        cpu_temp_raw=$(cat /sys/class/thermal/thermal_zone1/temp 2>/dev/null)
    fi
    if [ -n "$cpu_temp_raw" ] && [ "$cpu_temp_raw" -gt 0 ]; then
        cpu_temp=$(( cpu_temp_raw / 1000 ))
        cpu_temp_str="${cpu_temp}C"
    else
        cpu_temp_str="N/A"
    fi

    # C. Fetch System RAM usage
    ram_info=$(free -m | awk '/Mem:/ {printf "%.1f GB / %.1f GB (%.0f%%)\n", $3/1024, $2/1024, $3/$2*100}')

    # D. Pure Bash Disk I/O Speed Calculator
    current_read_sectors=0
    current_write_sectors=0
    while read -r _ _ dev r_sect _ _ _ w_sect _; do
        if [[ "$dev" =~ ^(nvme[0-9]n[0-9]|sd[a-z])$ ]]; then
            current_read_sectors=$((current_read_sectors + r_sect))
            current_write_sectors=$((current_write_sectors + w_sect))
        fi
    done < /proc/diskstats

    diff_read=$((current_read_sectors - prev_read_sectors))
    diff_write=$((current_write_sectors - prev_write_sectors))

    # Convert sectors to MB (1 sector = 512 bytes; 2048 sectors = 1 MB)
    if [ "$aider_running" -eq 1 ]; then
        # 0.2s loop interval -> multiply difference by 5 to get per-second rate
        read_mb=$(( diff_read * 5 / 2048 ))
        write_mb=$(( diff_write * 5 / 2048 ))
    else
        # 1.0s loop interval
        read_mb=$(( diff_read / 2048 ))
        write_mb=$(( diff_write / 2048 ))
    fi

    # Handle negative differences on first iteration or wrap-arounds
    if [ "$read_mb" -lt 0 ]; then read_mb=0; fi
    if [ "$write_mb" -lt 0 ]; then write_mb=0; fi

    prev_read_sectors=$current_read_sectors
    prev_write_sectors=$current_write_sectors

    disk_info="${read_mb} MB/s Read | ${write_mb} MB/s Write"

    echo -e "  ${CYAN}[ HARDWARE STATUS ]${NC}${EL}"
    echo -e "  VRAM Usage:   [${GREEN}${bar_filled}${GRAY}${bar_empty}${NC}] ${gpu_used_gb} GB / ${gpu_total_gb} GB (${gpu_pct}%)${EL}"
    echo -e "  GPU Load/Temp: [${GREEN}${gpu_load_bar_filled}${GRAY}${gpu_load_bar_empty}${NC}] ${YELLOW}${gpu_load}% Load${NC} | ${YELLOW}${gpu_temp}C${NC}${EL}"
    echo -e "  CPU Usage:    [${GREEN}${cpu_bar_filled}${GRAY}${cpu_bar_empty}${NC}] ${cpu_usage}% Load | ${YELLOW}${cpu_temp_str}${NC}${EL}"
    echo -e "  System RAM:    $ram_info${EL}"
    echo -e "  Disk I/O:      $disk_info${EL}"
    echo -e "${GRAY}$divider${NC}${EL}"
    echo -e "${EL}"

    # 5. Dynamic Aider Triple-Model Status Card
    arch_model="qwen3-coder:30b-tweaked"
    edit_model="qwen2.5-coder:7b-tweaked"
    trans_model="deepseek-coder-v2:16b-translate"

    # Check if Aider is actually running and scan its arguments
    aider_running=0
    aider_target_profile="qwen" # qwen, deepseek, translate, uncensored
    if pgrep -f "aider" >/dev/null; then
        aider_running=1
        aider_cmd=$(ps aux | grep -v grep | grep -E "aider|python -m aider" | tail -n 1)
        if [ -n "$aider_cmd" ]; then
            if echo "$aider_cmd" | grep -q "deepseek-coder-v2:16b-tweaked"; then
                trans_model="deepseek-coder-v2:16b-tweaked"
                aider_target_profile="deepseek"
            elif echo "$aider_cmd" | grep -q "deepseek-coder-v2:16b-translate"; then
                trans_model="deepseek-coder-v2:16b-translate"
                aider_target_profile="translate"
            elif echo "$aider_cmd" | grep -q "dolphin-llama3:8b-tweaked"; then
                trans_model="dolphin-llama3:8b-tweaked"
                aider_target_profile="uncensored"
            fi
        fi
    fi

    # Determine loaded status of each model in Ollama VRAM
    arch_active=0
    edit_active=0
    trans_active=0
    
    if echo "$models_output" | grep -q "30b-tweaked"; then
        arch_active=1
    fi
    if echo "$models_output" | grep -q "7b-tweaked"; then
        edit_active=1
    fi
    if echo "$models_output" | grep -q -E "16b-translate|16b-tweaked|dolphin-llama3"; then
        trans_active=1
    fi

    # Resolve highly granular system states
    is_compiling=0
    if pgrep -x vibe-check >/dev/null || pgrep -f dotnet >/dev/null || pgrep -f "godot --headless" >/dev/null; then
        is_compiling=1
    fi

    is_translating_file=0
    if pgrep -f vibe-translate >/dev/null || pgrep -f "generate -d .*16b-translate" >/dev/null; then
        is_translating_file=1
    fi

    # Detect high GPU activity
    is_gpu_busy=0
    if [ -n "$gpu_load" ] && [ "$gpu_load" != "N/A" ] 2>/dev/null; then
        if [ "$gpu_load" -gt 15 ] 2>/dev/null; then
            is_gpu_busy=1
        fi
    fi

    # Resolve ARCHITECT status
    if [ "$arch_active" -eq 1 ]; then
        if [ "$aider_running" -eq 1 ] && [ "$aider_target_profile" = "qwen" ] && [ "$is_gpu_busy" -eq 1 ] && [ "$edit_active" -eq 0 ]; then
            arch_status="${BLUE}[ THINKING  ]${NC} ◀ Designing system plan..."
        else
            arch_status="${GREEN}[  READY  ]${NC} ◀ Awaiting task..."
        fi
    else
        arch_status="${YELLOW}[ SLEEPING  ]${NC} ◀ Unloaded from VRAM"
    fi

    # Resolve EDITOR status
    if [ "$edit_active" -eq 1 ]; then
        if [ "$is_compiling" -eq 1 ]; then
            edit_status="${YELLOW}[ COMPILING ]${NC} ◀ Running vibe-check..."
        elif [ "$aider_running" -eq 1 ] && [ "$aider_target_profile" = "qwen" ] && [ "$is_gpu_busy" -eq 1 ] && [ "$arch_active" -eq 0 ]; then
            edit_status="${GREEN}[  WRITING  ]${NC} ◀ Applying diff blocks..."
        else
            edit_status="${GREEN}[  READY  ]${NC} ◀ Awaiting edits..."
        fi
    else
        if [ "$is_compiling" -eq 1 ]; then
            edit_status="${YELLOW}[ COMPILING ]${NC} ◀ Running vibe-check..."
        else
            edit_status="${YELLOW}[ SLEEPING  ]${NC} ◀ Unloaded from VRAM"
        fi
    fi

    # Resolve TRANSLATOR/UNCENSORED status
    if [ "$trans_active" -eq 1 ]; then
        if [ "$aider_running" -eq 1 ] && [ "$aider_target_profile" = "uncensored" ] && [ "$is_gpu_busy" -eq 1 ]; then
            trans_status="${RED}[UNLEASHED  ]${NC} ◀ Processing uncensored query..."
        elif [ "$is_translating_file" -eq 1 ] || { [ "$aider_running" -eq 1 ] && [ "$aider_target_profile" = "translate" ] && [ "$is_gpu_busy" -eq 1 ]; }; then
            trans_status="${MAGENTA}[TRANSLATING]${NC} ◀ Mapping logic & API..."
        elif [ "$aider_running" -eq 1 ] && [ "$aider_target_profile" = "deepseek" ] && [ "$is_gpu_busy" -eq 1 ]; then
            trans_status="${BLUE}[GENERATING ]${NC} ◀ Processing solution..."
        else
            trans_status="${GREEN}[  READY  ]${NC} ◀ Awaiting task..."
        fi
    else
        if [ "$is_translating_file" -eq 1 ]; then
            trans_status="${MAGENTA}[ LOADING   ]${NC} ◀ Spawning API call..."
        else
            trans_status="${YELLOW}[ SLEEPING  ]${NC} ◀ Unloaded from VRAM"
        fi
    fi

    # Handle Aider Overall Session status fallback when stopped
    if [ "$aider_running" -eq 0 ]; then
        if [ "$arch_active" -eq 1 ]; then arch_status="${GREEN}[  READY  ]${NC} (Aider stopped)"; fi
        if [ "$edit_active" -eq 1 ]; then edit_status="${GREEN}[  READY  ]${NC} (Aider stopped)"; fi
        if [ "$trans_active" -eq 1 ]; then trans_status="${GREEN}[  READY  ]${NC} (Aider stopped)"; fi
    fi

    # Dynamically change the role label on row 3 depending on model
    trans_role="Translator"
    if [[ "$trans_model" == *"dolphin"* ]]; then
        trans_role="Uncensored"
    fi

    echo -e "  ${CYAN}[ OLLAMA TRIPLE-MODEL STATUS ]${NC}${EL}"
    echo -e "  ROLE          MODEL NAME                      STATUS / VRAM STATE${EL}"
    echo -e "  ----          ----------                      -------------------${EL}"
    echo -e "  Architect     $(printf '%-30s' "$arch_model")  $arch_status${EL}"
    echo -e "  Editor        $(printf '%-30s' "$edit_model")  $edit_status${EL}"
    echo -e "  $(printf '%-13s' "$trans_role")$(printf '%-30s' "$trans_model")  $trans_status${EL}"
    echo -e "${EL}"
    echo -e "${CYAN}$border${NC}${EL}"
    echo -e "  Press [Ctrl+C] to exit HUD.                       ${EL}"
    
    # Silently clear the rest of the screen below the HUD
    tput ed
    
    # Adapt sleep interval depending on active usage to save CPU/Battery
    if [ "$aider_running" -eq 1 ]; then
        sleep 0.2
    else
        sleep 1.0
    fi
done
