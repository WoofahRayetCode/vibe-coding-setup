#!/bin/bash

# Colors for terminal output
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
GRAY='\033[0;90m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Clear screen initially
clear

# Hide cursor
tput civis

# Flag to track if the static ASCII header has been drawn
header_drawn=0

# Restore cursor on exit
trap 'tput cnorm; exit' INT TERM EXIT

# Trap window resize signals to force a header redraw
trap 'clear; header_drawn=0' WINCH

draw_static_header() {
    cols=$(tput cols)
    border=$(printf -- '=%.0s' $(seq 1 $cols))
    
    tput cup 0 0
    echo -e "${CYAN}$border${NC}"
    echo -e "${CYAN} __     ___ _            _   _ _   _ ____   ${NC}"
    echo -e "${CYAN} \\ \\   / (_) |__   ___  | | | | | | |  _ \\  ${NC}"
    echo -e "${CYAN}  \\ \\ / /| | '_ \\ / _ \\ | |_| | | | | | | | ${NC}"
    echo -e "${CYAN}   \\ V / | | |_) |  __/ |  _  | |_| | |_| | ${NC}"
    echo -e "${CYAN}    \\_/  |_|_.__/ \\___| |_| |_|\\___/|____/  ${NC}"
    echo -e "${CYAN}$border${NC}"
    header_drawn=1
}

while true; do
    # 1. Draw static header only if not already drawn (or resized)
    if [ "$header_drawn" -eq 0 ]; then
        draw_static_header
    fi

    # Fetch terminal dimensions
    cols=$(tput cols)
    lines=$(tput lines)
    divider=$(printf -- '-%.0s' $(seq 1 $cols))
    border=$(printf -- '=%.0s' $(seq 1 $cols))

    # Fetch active models
    models_output=$(ollama ps 2>/dev/null | tail -n +2)

    # 2. Move cursor directly to Line 9 (0-indexed line 8) below the ASCII art
    tput cup 8 0

    # 3. Print Dynamic Info (Time & Shell)
    current_time=$(date +"%Y-%m-%d %H:%M:%S")
    echo -e "  ${CYAN}[ SYSTEM TIME ]${NC}  $current_time"
    echo -e "  ${CYAN}[ HOST SHELL  ]${NC}  $SHELL"
    echo -e "${GRAY}$divider${NC}"
    echo ""

    # 4. Fetch and Print Live Hardware Telemetry
    gpu_info=$(nvidia-smi --query-gpu=memory.used,memory.total,utilization.gpu,temperature.gpu --format=csv,noheader,nounits 2>/dev/null)
    if [ -n "$gpu_info" ]; then
        gpu_used=$(echo "$gpu_info" | awk -F', ' '{print $1}')
        gpu_total=$(echo "$gpu_info" | awk -F', ' '{print $2}')
        gpu_load=$(echo "$gpu_info" | awk -F', ' '{print $3}')
        gpu_temp=$(echo "$gpu_info" | awk -F', ' '{print $4}')

        # Floating point calculations in pure Bash
        used_gb_val=$(( gpu_used / 1024 ))
        used_mb_val=$(( (gpu_used % 1024) * 10 / 1024 ))
        gpu_used_gb="${used_gb_val}.${used_mb_val}"

        total_gb_val=$(( gpu_total / 1024 ))
        total_mb_val=$(( (gpu_total % 1024) * 10 / 1024 ))
        gpu_total_gb="${total_gb_val}.${total_mb_val}"

        gpu_pct=$(( gpu_used * 100 / gpu_total ))

        # Create VRAM Progress Bar
        bar_width=12
        filled=$(( gpu_pct * bar_width / 100 ))
        empty=$(( bar_width - filled ))
        
        if [ "$filled" -gt 0 ]; then
            bar_filled=$(printf -- '█%.0s' $(seq 1 $filled))
        else
            bar_filled=""
        fi
        if [ "$empty" -gt 0 ]; then
            bar_empty=$(printf -- '░%.0s' $(seq 1 $empty))
        else
            bar_empty=""
        fi
    else
        gpu_used_gb="N/A"
        gpu_total_gb="N/A"
        gpu_pct=0
        gpu_load="N/A"
        gpu_temp="N/A"
        bar_filled=""
        bar_empty="░░░░░░░░░░░░"
    fi

    # Fetch System RAM usage
    ram_info=$(free -m | awk '/Mem:/ {printf "%.1f GB / %.1f GB (%.0f%%)\n", $3/1024, $2/1024, $3/$2*100}')

    echo -e "  ${CYAN}[ HARDWARE STATUS ]${NC}"
    echo -e "  VRAM Usage:   [${GREEN}${bar_filled}${GRAY}${bar_empty}${NC}] ${gpu_used_gb} GB / ${gpu_total_gb} GB (${gpu_pct}%)"
    echo -e "  GPU Load/Temp: ${YELLOW}${gpu_load}% Load${NC} | ${YELLOW}${gpu_temp}°C${NC}"
    echo -e "  System RAM:    $ram_info"
    echo -e "${GRAY}$divider${NC}"
    echo ""

    # 5. Print Ollama Model Info
    if [ -z "$models_output" ]; then
        echo -e "  ${GRAY}STATUS:       Idle (No models active in VRAM)${NC}               "
        echo ""
        echo -e "  Active Model: ${GRAY}None${NC}                                 "
        echo -e "  Processor:    ${GRAY}N/A${NC}                                      "
        echo -e "  Cache Unload: ${GRAY}N/A${NC}                                      "
    else
        echo -e "  ${GREEN}STATUS:     Active (AI Model is currently executing)${NC}       "
        echo ""
        
        # Read the ollama ps columns
        echo "$models_output" | while read -r line; do
            if [ -n "$line" ]; then
                model_name=$(echo "$line" | awk '{print $1}')
                size=$(echo "$line" | awk '{print $3 " " $4}')
                processor=$(echo "$line" | awk '{print $5}')
                until_time=$(echo "$line" | awk '{print $(NF-4) " " $(NF-3) " " $(NF-2) " " $(NF-1) " " $NF}')
                
                # Apply custom colors based on model family
                if [[ "$model_name" == *"30b"* ]]; then
                    color="${BLUE}"
                else
                    color="${GREEN}"
                fi

                echo -e "  Active Model: ${color}${model_name}${NC} (${size})        "
                echo -e "  Processor:    ${YELLOW}${processor}${NC}                 "
                echo -e "  Cache Unload: ${GRAY}${until_time}${NC}                    "
            fi
        done
    fi
    echo ""
    echo -e "${CYAN}$border${NC}"
    echo -e "  Press [Ctrl+C] to exit HUD.                       "
    
    # Silently clear the rest of the screen below the HUD
    tput ed
    
    sleep 0.2
done
