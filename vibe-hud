#!/bin/bash

# Colors for terminal output
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
GRAY='\033[0;90m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
EL='\033[K'  # Clear to end of line

# Clear screen initially
clear

# Hide cursor
tput civis

# Flag to track if the static ASCII header has been drawn
header_drawn=0

# Variables for pure Bash CPU calculation
prev_idle=0
prev_total=0

# Variables for pure Bash Disk I/O calculation
prev_read_sectors=0
prev_write_sectors=0

# Variables for pure Bash Network I/O calculation
prev_rx_bytes=0
prev_tx_bytes=0

# Variables for scrolling News Tickers (Engines, Languages, and LLM Models)
ticker_engines=" [GODOT MASTER] Typed Dictionaries are now natively compiled for 3x faster iterations.  |  [GAMEMAKER BETA] Dynamic Audio Effect bus routing and persistent GML structs optimized.  |  [GODOT MASTER] RenderingDevice GL Compatibility pipeline optimized for laptop GPUs.  |  [GAMEMAKER BETA] New vector particle shapes and physics bindings added. "
idx_engines=0

ticker_languages=" [PYTHON MASTER] Experimental Free-Threaded build (PEP 703) enables true GIL-free multicore parallel execution.  |  [PYTHON MASTER] Experimental Tier 2 JIT compiler (PEP 744) enabled dynamically for 15% faster hot loops.  |  [PYTHON MASTER] Brand new colorized interactive REPL featuring multi-line editing now active. "
idx_languages=0

ticker_models=" [QWEN 30B] Architect model optimized with 16K context windows for complex systems planning.  |  [QWEN 7B] Editor model locked at Temperature 0 for rapid, deterministic diff modifications.  |  [DEEPSEEK 16B] Specialized translator profile handles cross-language APIs with full comments preservation.  |  [DOLPHIN 8B] Uncensored model locks all 33 layers into VRAM for boundary-free programming. "
idx_models=0

# Frames for thinking ASCII question mark animation (4 frames, 4 lines each)
q_frame0_0="   .---. "
q_frame0_1="  /  .  \\"
q_frame0_2="    /  / "
q_frame0_3="    (o)  "

q_frame1_0="   .---. "
q_frame1_1="  /  .  \\"
q_frame1_2="    |  | "
q_frame1_3="    (O)  "

q_frame2_0="   .---. "
q_frame2_1="  /  .  \\"
q_frame2_2="    \\  \\ "
q_frame2_3="    (o)  "

q_frame3_0="   .---. "
q_frame3_1="  /  .  \\"
q_frame3_2="    |  | "
q_frame3_3="    (O)  "

# Restore cursor on exit
trap 'tput cnorm; exit' INT TERM EXIT

# Trap window resize signals to force a clear
trap 'clear' WINCH

# Background update checker function (Runs asynchronously in separate subshell)
check_model_updates() {
    sleep 5
    while true; do
        updates=""
        
        # Local model list
        local_list=$(ollama list 2>/dev/null)
        if [ -n "$local_list" ]; then
            # Check Qwen 30B
            local_id=$(echo "$local_list" | grep "^qwen3-coder:30b[[:space:]]" | awk '{print $2}')
            if [ -n "$local_id" ]; then
                remote_digest=$(curl -sI "https://registry.ollama.ai/v2/library/qwen3-coder/manifests/30b" | grep -i "ollama-content-digest" | awk '{print $2}' | tr -d '\r\n')
                if [ -n "$remote_digest" ] && [[ "$remote_digest" != "$local_id"* ]]; then
                    updates="${updates}qwen3-coder:30b "
                fi
            fi

            # Check Qwen 7B
            local_id=$(echo "$local_list" | grep "^qwen2.5-coder:7b[[:space:]]" | awk '{print $2}')
            if [ -n "$local_id" ]; then
                remote_digest=$(curl -sI "https://registry.ollama.ai/v2/library/qwen2.5-coder/manifests/7b" | grep -i "ollama-content-digest" | awk '{print $2}' | tr -d '\r\n')
                if [ -n "$remote_digest" ] && [[ "$remote_digest" != "$local_id"* ]]; then
                    updates="${updates}qwen2.5-coder:7b "
                fi
            fi

            # Check DeepSeek 16B
            local_id=$(echo "$local_list" | grep "^deepseek-coder-v2:16b[[:space:]]" | awk '{print $2}')
            if [ -n "$local_id" ]; then
                remote_digest=$(curl -sI "https://registry.ollama.ai/v2/library/deepseek-coder-v2/manifests/16b" | grep -i "ollama-content-digest" | awk '{print $2}' | tr -d '\r\n')
                if [ -n "$remote_digest" ] && [[ "$remote_digest" != "$local_id"* ]]; then
                    updates="${updates}deepseek-coder-v2:16b "
                fi
            fi

            # Check Dolphin 8B
            local_id=$(echo "$local_list" | grep "^dolphin-llama3:8b[[:space:]]" | awk '{print $2}')
            if [ -n "$local_id" ]; then
                remote_digest=$(curl -sI "https://registry.ollama.ai/v2/library/dolphin-llama3/manifests/8b" | grep -i "ollama-content-digest" | awk '{print $2}' | tr -d '\r\n')
                if [ -n "$remote_digest" ] && [[ "$remote_digest" != "$local_id"* ]]; then
                    updates="${updates}dolphin-llama3:8b "
                fi
            fi
        fi

        # Save to cache file
        mkdir -p "$HOME/.cache"
        echo "$updates" > "$HOME/.cache/vibe-model-updates.txt"

        # Check every 30 minutes
        sleep 1800
    done
}

# Start the background update checker daemon
check_model_updates &

draw_header() {
    cols=$(tput cols)
    border=$(printf -- '=%.0s' $(seq 1 $cols))
    echo -e "${CYAN}$border${NC}${EL}"
    echo -e "${CYAN} __     ___ _            _   _ _   _ ____   ${NC}${EL}"
    echo -e "${CYAN} \\ \\   / (_) |__   ___  | | | | | | |  _ \\  ${NC}${EL}"
    echo -e "${CYAN}  \\ \\ / /| | '_ \\ / _ \\ | |_| | | | | | | | ${NC}${EL}"
    echo -e "${CYAN}   \\ V / | | |_) |  __/ |  _  | |_| | |_| | ${NC}${EL}"
    echo -e "${CYAN}    \\_/  |_|_.__/ \\___| |_| |_|\\___/|____/  ${NC}${EL}"
    echo -e "${CYAN}$border${NC}${EL}"
}

while true; do
    # 1. Reset cursor to top-left to redraw cleanly without scrolling
    tput cup 0 0
    draw_header

    # Fetch terminal dimensions
    cols=$(tput cols)
    lines=$(tput lines)
    divider=$(printf -- '-%.0s' $(seq 1 $cols))
    border=$(printf -- '=%.0s' $(seq 1 $cols))

    # Fetch active models
    models_output=$(ollama ps 2>/dev/null | tail -n +2)

    # 2. Print Dynamic Info (Time & Shell) & thinking question mark columns
    current_time=$(date +"%Y-%m-%d %H:%M:%S")

    # Select animation frame
    frame_idx=$(( ticker_idx % 4 ))
    case $frame_idx in
        0) q_l0="$q_frame0_0"; q_l1="$q_frame0_1"; q_l2="$q_frame0_2"; q_l3="$q_frame0_3" ;;
        1) q_l0="$q_frame1_0"; q_l1="$q_frame1_1"; q_l2="$q_frame1_2"; q_l3="$q_frame1_3" ;;
        2) q_l0="$q_frame2_0"; q_l1="$q_frame2_1"; q_l2="$q_frame2_2"; q_l3="$q_frame2_3" ;;
        3) q_l0="$q_frame3_0"; q_l1="$q_frame3_1"; q_l2="$q_frame3_2"; q_l3="$q_frame3_3" ;;
    esac

    col_w=$(( cols - 16 ))
    if [ "$col_w" -lt 30 ]; then col_w=30; fi

    # Time line
    line_time=$(printf "  %-*s" $col_w "${CYAN}[ SYSTEM TIME ]${NC}  $current_time")
    echo -e "${line_time}${YELLOW}${q_l0}${NC}${EL}"

    # Shell line
    line_shell=$(printf "  %-*s" $col_w "${CYAN}[ HOST SHELL  ]${NC}  $SHELL")
    echo -e "${line_shell}${YELLOW}${q_l1}${NC}${EL}"

    # Directory line (truncated safely if too long)
    pwd_str=$(pwd)
    max_pwd_len=$(( col_w - 20 ))
    if [ "${#pwd_str}" -gt "$max_pwd_len" ]; then
        pwd_str="...${pwd_str: -$((max_pwd_len - 3))}"
    fi
    line_dir=$(printf "  %-*s" $col_w "${CYAN}[ WORKING DIR ]${NC}  $pwd_str")
    echo -e "${line_dir}${YELLOW}${q_l2}${NC}${EL}"

    # Read model updates cache and format notification badge
    update_line=""
    if [ -f "$HOME/.cache/vibe-model-updates.txt" ]; then
        updates=$(cat "$HOME/.cache/vibe-model-updates.txt")
        if [ -n "$updates" ]; then
            update_line="  ${RED}[ UPDATE AVAILABLE ]${NC} ${YELLOW}New versions found for: ${updates}(Run setup.sh to rebuild)${EL}"
        fi
    fi

    # Print Notification + Animation line 4
    if [ -n "$update_line" ]; then
        line_upd=$(printf "  %-*s" $col_w "$update_line")
        echo -e "${line_upd}${YELLOW}${q_l3}${NC}${EL}"
    else
        line_blank=$(printf "  %-*s" $col_w " ")
        echo -e "${line_blank}${YELLOW}${q_l3}${NC}${EL}"
    fi
    
    echo -e "${GRAY}$divider${NC}${EL}"
    echo -e "${EL}"

    # 4. Fetch and Print Live Hardware Telemetry
    # A. NVIDIA GPU & VRAM Status
    gpu_info=$(nvidia-smi --query-gpu=memory.used,memory.total,utilization.gpu,temperature.gpu --format=csv,noheader,nounits 2>/dev/null)
    if [ -n "$gpu_info" ]; then
        gpu_used=$(echo "$gpu_info" | awk -F', ' '{print $1}')
        gpu_total=$(echo "$gpu_info" | awk -F', ' '{print $2}')
        gpu_load=$(echo "$gpu_info" | awk -F', ' '{print $3}')
        gpu_temp=$(echo "$gpu_info" | awk -F', ' '{print $4}')

        # Floating point calculations in pure Bash
        used_gb_val=$(( gpu_used / 1024 ))
        used_mb_val=$(( (gpu_used % 1024) * 10 / 1024 ))
        gpu_used_gb="${used_gb_val}.${used_mb_val}"

        total_gb_val=$(( gpu_total / 1024 ))
        total_mb_val=$(( (gpu_total % 1024) * 10 / 1024 ))
        gpu_total_gb="${total_gb_val}.${total_mb_val}"

        gpu_pct=$(( gpu_used * 100 / gpu_total ))

        # Create VRAM Progress Bar
        bar_width=12
        filled=$(( gpu_pct * bar_width / 100 ))
        empty=$(( bar_width - filled ))
        
        if [ "$filled" -gt 0 ]; then
            bar_filled=$(printf -- '█%.0s' $(seq 1 $filled))
        else
            bar_filled=""
        fi
        if [ "$empty" -gt 0 ]; then
            bar_empty=$(printf -- '░%.0s' $(seq 1 $empty))
        else
            bar_empty=""
        fi

        # Create GPU Load Progress Bar
        gpu_load_filled=$(( gpu_load * bar_width / 100 ))
        gpu_load_empty=$(( bar_width - gpu_load_filled ))

        if [ "$gpu_load_filled" -gt 0 ]; then
            gpu_load_bar_filled=$(printf -- '█%.0s' $(seq 1 $gpu_load_filled))
        else
            gpu_load_bar_filled=""
        fi
        if [ "$gpu_load_empty" -gt 0 ]; then
            gpu_load_bar_empty=$(printf -- '░%.0s' $(seq 1 $gpu_load_empty))
        else
            gpu_load_bar_empty=""
        fi
    else
        gpu_used_gb="N/A"
        gpu_total_gb="N/A"
        gpu_pct=0
        gpu_load="N/A"
        gpu_temp="N/A"
        bar_filled=""
        bar_empty="░░░░░░░░░░░░"
        gpu_load_bar_filled=""
        gpu_load_bar_empty="░░░░░░░░░░░░"
    fi

    # B. Pure Bash CPU Utilization Calculator (reads ticks since last 0.2s loop)
    read -r _ user nice system idle iowait irq softirq steal guest guest_nice < /proc/stat
    total_ticks=$((user + nice + system + idle + iowait + irq + softirq + steal))
    idle_ticks=$idle

    diff_total=$((total_ticks - prev_total))
    diff_idle=$((idle_ticks - prev_idle))

    if [ "$diff_total" -gt 0 ]; then
        cpu_usage=$(( (diff_total - diff_idle) * 100 / diff_total ))
    else
        cpu_usage=0
    fi

    prev_total=$total_ticks
    prev_idle=$idle_ticks

    # Create CPU Progress Bar
    cpu_bar_width=12
    cpu_filled=$(( cpu_usage * cpu_bar_width / 100 ))
    cpu_empty=$(( cpu_bar_width - cpu_filled ))
    
    if [ "$cpu_filled" -gt 0 ]; then
        cpu_bar_filled=$(printf -- '█%.0s' $(seq 1 $cpu_filled))
    else
        cpu_bar_filled=""
    fi
    if [ "$cpu_empty" -gt 0 ]; then
        cpu_bar_empty=$(printf -- '░%.0s' $(seq 1 $cpu_empty))
    else
        cpu_bar_empty=""
    fi

    # Fetch CPU temperature dynamically from /sys/class/thermal
    cpu_temp_raw=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null)
    if [ -z "$cpu_temp_raw" ]; then
        cpu_temp_raw=$(cat /sys/class/thermal/thermal_zone1/temp 2>/dev/null)
    fi
    if [ -n "$cpu_temp_raw" ] && [ "$cpu_temp_raw" -gt 0 ]; then
        cpu_temp=$(( cpu_temp_raw / 1000 ))
        cpu_temp_str="${cpu_temp}C"
    else
        cpu_temp_str="N/A"
    fi

    # C. Fetch System RAM usage
    ram_info=$(free -m | awk '/Mem:/ {printf "%.1f GB / %.1f GB (%.0f%%)\n", $3/1024, $2/1024, $3/$2*100}')
    ram_pct=$(free | awk '/Mem:/ {print int($3/$2 * 100)}')
    if [ -z "$ram_pct" ]; then ram_pct=0; fi

    # Create System RAM Progress Bar
    ram_bar_width=12
    ram_filled=$(( ram_pct * ram_bar_width / 100 ))
    ram_empty=$(( ram_bar_width - ram_filled ))

    if [ "$ram_filled" -gt 0 ]; then
        ram_bar_filled=$(printf -- '█%.0s' $(seq 1 $ram_filled))
    else
        ram_bar_filled=""
    fi
    if [ "$ram_empty" -gt 0 ]; then
        ram_bar_empty=$(printf -- '░%.0s' $(seq 1 $ram_empty))
    else
        ram_bar_empty=""
    fi

    # D. Pure Bash Disk I/O Speed Calculator
    current_read_sectors=0
    current_write_sectors=0
    while read -r _ _ dev r_sect _ _ _ w_sect _; do
        if [[ "$dev" =~ ^(nvme[0-9]n[0-9]|sd[a-z])$ ]]; then
            current_read_sectors=$((current_read_sectors + r_sect))
            current_write_sectors=$((current_write_sectors + w_sect))
        fi
    done < /proc/diskstats

    diff_read=$((current_read_sectors - prev_read_sectors))
    diff_write=$((current_write_sectors - prev_write_sectors))

    # Convert sectors to MB (1 sector = 512 bytes; 2048 sectors = 1 MB)
    if [ "$aider_running" -eq 1 ]; then
        # 0.2s loop interval -> multiply difference by 5 to get per-second rate
        read_mb=$(( diff_read * 5 / 2048 ))
        write_mb=$(( diff_write * 5 / 2048 ))
    else
        # 1.0s loop interval
        read_mb=$(( diff_read / 2048 ))
        write_mb=$(( diff_write / 2048 ))
    fi

    # Handle negative differences on first iteration or wrap-arounds
    if [ "$read_mb" -lt 0 ]; then read_mb=0; fi
    if [ "$write_mb" -lt 0 ]; then write_mb=0; fi

    prev_read_sectors=$current_read_sectors
    prev_write_sectors=$current_write_sectors

    disk_info="${read_mb} MB/s Read | ${write_mb} MB/s Write"

    # Create Disk Progress Bar (scaled to a high-speed 1000 MB/s active threshold)
    disk_total=$(( read_mb + write_mb ))
    disk_pct=$(( disk_total * 100 / 1000 ))
    if [ "$disk_pct" -gt 100 ]; then disk_pct=100; fi

    disk_bar_width=12
    disk_filled=$(( disk_pct * disk_bar_width / 100 ))
    disk_empty=$(( disk_bar_width - disk_filled ))

    if [ "$disk_filled" -gt 0 ]; then
        disk_bar_filled=$(printf -- '█%.0s' $(seq 1 $disk_filled))
    else
        disk_bar_filled=""
    fi
    if [ "$disk_empty" -gt 0 ]; then
        disk_bar_empty=$(printf -- '░%.0s' $(seq 1 $disk_empty))
    else
        disk_bar_empty=""
    fi

    # E. Pure Bash Network I/O Speed Calculator (Single Awk parse for 0% CPU)
    net_data=$(awk '/wlan|eno|enp|eth/ {rx+=$2; tx+=$10} END {print rx, tx}' /proc/net/dev 2>/dev/null)
    current_rx_bytes=$(echo "$net_data" | awk '{print $1}')
    current_tx_bytes=$(echo "$net_data" | awk '{print $2}')

    if [ -z "$current_rx_bytes" ]; then current_rx_bytes=0; fi
    if [ -z "$current_tx_bytes" ]; then current_tx_bytes=0; fi

    diff_rx=$((current_rx_bytes - prev_rx_bytes))
    diff_tx=$((current_tx_bytes - prev_tx_bytes))

    if [ "$aider_running" -eq 1 ]; then
        # 0.2s loop interval -> multiply difference by 5 to get per-second rate
        rx_kb=$(( diff_rx * 5 / 1024 ))
        tx_kb=$(( diff_tx * 5 / 1024 ))
    else
        # 1.0s loop interval
        rx_kb=$(( diff_rx / 1024 ))
        tx_kb=$(( diff_tx / 1024 ))
    fi

    # Handle negative differences on first iteration or wrap-arounds
    if [ "$rx_kb" -lt 0 ]; then rx_kb=0; fi
    if [ "$tx_kb" -lt 0 ]; then tx_kb=0; fi

    prev_rx_bytes=$current_rx_bytes
    prev_tx_bytes=$current_tx_bytes

    if [ "$rx_kb" -gt 1024 ]; then
        rx_str="$(( rx_kb / 1024 )) MB/s"
    else
        rx_str="${rx_kb} KB/s"
    fi

    if [ "$tx_kb" -gt 1024 ]; then
        tx_str="$(( tx_kb / 1024 )) MB/s"
    else
        tx_str="${tx_kb} KB/s"
    fi

    net_info="${rx_str} Down | ${tx_str} Up"

    # Create Network Progress Bar (scaled to a high-speed 10 MB/s active threshold)
    net_total=$(( rx_kb + tx_kb ))
    net_pct=$(( net_total * 100 / 10240 ))
    if [ "$net_pct" -gt 100 ]; then net_pct=100; fi

    net_bar_width=12
    net_filled=$(( net_pct * net_bar_width / 100 ))
    net_empty=$(( net_bar_width - net_filled ))

    if [ "$net_filled" -gt 0 ]; then
        net_bar_filled=$(printf -- '█%.0s' $(seq 1 $net_filled))
    else
        net_bar_filled=""
    fi
    if [ "$net_empty" -gt 0 ]; then
        net_bar_empty=$(printf -- '░%.0s' $(seq 1 $net_empty))
    else
        net_bar_empty=""
    fi

    echo -e "  ${CYAN}[ HARDWARE STATUS ]${NC}${EL}"
    echo -e "  VRAM Usage:   [${GREEN}${bar_filled}${GRAY}${bar_empty}${NC}] ${gpu_used_gb} GB / ${gpu_total_gb} GB (${gpu_pct}%)${EL}"
    echo -e "  GPU Load/Temp: [${GREEN}${gpu_load_bar_filled}${GRAY}${gpu_load_bar_empty}${NC}] ${YELLOW}${gpu_load}% Load${NC} | ${YELLOW}${gpu_temp}C${NC}${EL}"
    echo -e "  CPU Usage:    [${GREEN}${cpu_bar_filled}${GRAY}${cpu_bar_empty}${NC}] ${cpu_usage}% Load | ${YELLOW}${cpu_temp_str}${NC}${EL}"
    echo -e "  System RAM:    [${GREEN}${ram_bar_filled}${GRAY}${ram_bar_empty}${NC}] $ram_info${EL}"
    echo -e "  Disk I/O:      [${GREEN}${disk_bar_filled}${GRAY}${disk_bar_empty}${NC}] ${disk_info}${EL}"
    echo -e "  Network:       [${GREEN}${net_bar_filled}${GRAY}${net_bar_empty}${NC}] ${net_info}${EL}"
    echo -e "${GRAY}$divider${NC}${EL}"
    echo -e "${EL}"

    # 5. Dynamic Aider Triple-Model Status Card
    arch_model="qwen3-coder:30b-tweaked"
    edit_model="qwen2.5-coder:7b-tweaked"
    trans_model="deepseek-coder-v2:16b-translate"

    # Check if Aider is actually running and scan its arguments
    aider_running=0
    aider_target_profile="qwen" # qwen, deepseek, translate, uncensored
    if pgrep -f "aider" >/dev/null; then
        aider_running=1
        aider_cmd=$(ps aux | grep -v grep | grep -E "aider|python -m aider" | tail -n 1)
        if [ -n "$aider_cmd" ]; then
            if echo "$aider_cmd" | grep -q "deepseek-coder-v2:16b-tweaked"; then
                trans_model="deepseek-coder-v2:16b-tweaked"
                aider_target_profile="deepseek"
            elif echo "$aider_cmd" | grep -q "deepseek-coder-v2:16b-translate"; then
                trans_model="deepseek-coder-v2:16b-translate"
                aider_target_profile="translate"
            elif echo "$aider_cmd" | grep -q "dolphin-llama3:8b-tweaked"; then
                trans_model="dolphin-llama3:8b-tweaked"
                aider_target_profile="uncensored"
            fi
        fi
    fi

    # Determine loaded status of each model in Ollama VRAM
    arch_active=0
    edit_active=0
    trans_active=0
    
    if echo "$models_output" | grep -q "30b-tweaked"; then
        arch_active=1
    fi
    if echo "$models_output" | grep -q "7b-tweaked"; then
        edit_active=1
    fi
    if echo "$models_output" | grep -q -E "16b-translate|16b-tweaked|dolphin-llama3"; then
        trans_active=1
    fi

    # Resolve highly granular system states
    is_compiling=0
    if pgrep -x vibe-check >/dev/null || pgrep -f dotnet >/dev/null || pgrep -f "godot --headless" >/dev/null; then
        is_compiling=1
    fi

    is_translating_file=0
    if pgrep -f vibe-translate >/dev/null || pgrep -f "generate -d .*16b-translate" >/dev/null; then
        is_translating_file=1
    fi

    # Detect high GPU activity
    is_gpu_busy=0
    if [ -n "$gpu_load" ] && [ "$gpu_load" != "N/A" ] 2>/dev/null; then
        if [ "$gpu_load" -gt 15 ] 2>/dev/null; then
            is_gpu_busy=1
        fi
    fi

    # Resolve ARCHITECT status
    if [ "$arch_active" -eq 1 ]; then
        if [ "$aider_running" -eq 1 ] && [ "$aider_target_profile" = "qwen" ] && [ "$is_gpu_busy" -eq 1 ] && [ "$edit_active" -eq 0 ]; then
            arch_status="${BLUE}[ THINKING  ]${NC} ◀ Designing system plan..."
        else
            arch_status="${GREEN}[  READY  ]${NC} ◀ Awaiting task..."
        fi
    else
        arch_status="${YELLOW}[ SLEEPING  ]${NC} ◀ Unloaded from VRAM"
    fi

    # Resolve EDITOR status
    if [ "$edit_active" -eq 1 ]; then
        if [ "$is_compiling" -eq 1 ]; then
            edit_status="${YELLOW}[ COMPILING ]${NC} ◀ Running vibe-check..."
        elif [ "$aider_running" -eq 1 ] && [ "$aider_target_profile" = "qwen" ] && [ "$is_gpu_busy" -eq 1 ] && [ "$arch_active" -eq 0 ]; then
            edit_status="${GREEN}[  WRITING  ]${NC} ◀ Applying diff blocks..."
        else
            edit_status="${GREEN}[  READY  ]${NC} ◀ Awaiting edits..."
        fi
    else
        if [ "$is_compiling" -eq 1 ]; then
            edit_status="${YELLOW}[ COMPILING ]${NC} ◀ Running vibe-check..."
        else
            edit_status="${YELLOW}[ SLEEPING  ]${NC} ◀ Unloaded from VRAM"
        fi
    fi

    # Resolve TRANSLATOR/UNCENSORED status
    if [ "$trans_active" -eq 1 ]; then
        if [ "$aider_running" -eq 1 ] && [ "$aider_target_profile" = "uncensored" ] && [ "$is_gpu_busy" -eq 1 ]; then
            trans_status="${RED}[UNLEASHED  ]${NC} ◀ Processing uncensored query..."
        elif [ "$is_translating_file" -eq 1 ] || { [ "$aider_running" -eq 1 ] && [ "$aider_target_profile" = "translate" ] && [ "$is_gpu_busy" -eq 1 ]; }; then
            trans_status="${MAGENTA}[TRANSLATING]${NC} ◀ Mapping logic & API..."
        elif [ "$aider_running" -eq 1 ] && [ "$aider_target_profile" = "deepseek" ] && [ "$is_gpu_busy" -eq 1 ]; then
            trans_status="${BLUE}[GENERATING ]${NC} ◀ Processing solution..."
        else
            trans_status="${GREEN}[  READY  ]${NC} ◀ Awaiting task..."
        fi
    else
        if [ "$is_translating_file" -eq 1 ]; then
            trans_status="${MAGENTA}[ LOADING   ]${NC} ◀ Spawning API call..."
        else
            trans_status="${YELLOW}[ SLEEPING  ]${NC} ◀ Unloaded from VRAM"
        fi
    fi

    # Handle Aider Overall Session status fallback when stopped
    if [ "$aider_running" -eq 0 ]; then
        if [ "$arch_active" -eq 1 ]; then arch_status="${GREEN}[  READY  ]${NC} (Aider stopped)"; fi
        if [ "$edit_active" -eq 1 ]; then edit_status="${GREEN}[  READY  ]${NC} (Aider stopped)"; fi
        if [ "$trans_active" -eq 1 ]; then trans_status="${GREEN}[  READY  ]${NC} (Aider stopped)"; fi
    fi

    # Dynamically change the role label on row 3 depending on model
    trans_role="Translator"
    if [[ "$trans_model" == *"dolphin"* ]]; then
        trans_role="Uncensored"
    fi

    echo -e "  ${CYAN}[ OLLAMA TRIPLE-MODEL STATUS ]${NC}${EL}"
    echo -e "  ROLE          MODEL NAME                      STATUS / VRAM STATE${EL}"
    echo -e "  ----          ----------                      -------------------${EL}"
    echo -e "  Architect     $(printf '%-30s' "$arch_model")  $arch_status${EL}"
    echo -e "  Editor        $(printf '%-30s' "$edit_model")  $edit_status${EL}"
    echo -e "  $(printf '%-13s' "$trans_role")$(printf '%-30s' "$trans_model")  $trans_status${EL}"
    echo -e "${EL}"

    # Scrolling Tickers Logic (Engines, Languages, and LLM Models)
    cols=$(tput cols)
    ticker_w=$(( cols - 22 )) # 22 chars for labels padding
    if [ "$ticker_w" -lt 10 ]; then ticker_w=10; fi

    # Ticker 1: Engines (Godot & GameMaker)
    extended_engines="${ticker_engines}${ticker_engines}"
    len_engines=${#ticker_engines}
    slice_engines="${extended_engines:$idx_engines:$ticker_w}"
    idx_engines=$(( (idx_engines + 1) % len_engines ))

    # Ticker 2: Languages (Python)
    extended_languages="${ticker_languages}${ticker_languages}"
    len_languages=${#ticker_languages}
    slice_languages="${extended_languages:$idx_languages:$ticker_w}"
    idx_languages=$(( (idx_languages + 1) % len_languages ))

    # Ticker 3: Models (LLMs)
    extended_models="${ticker_models}${ticker_models}"
    len_models=${#ticker_models}
    slice_models="${extended_models:$idx_models:$ticker_w}"
    idx_models=$(( (idx_models + 1) % len_models ))

    echo -e "  ${CYAN}« ENGINES NEWS »${NC}  ${YELLOW}${slice_engines}${NC}${EL}"
    echo -e "  ${GREEN}« LANGS  NEWS »${NC}  ${YELLOW}${slice_languages}${NC}${EL}"
    echo -e "  ${MAGENTA}« MODELS NEWS »${NC}  ${YELLOW}${slice_models}${NC}${EL}"
    echo -e "${EL}"
    echo -e "${CYAN}$border${NC}${EL}"
    echo -e "  Press [Ctrl+C] to exit HUD.                       ${EL}"
    
    # Silently clear the rest of the screen below the HUD
    tput ed
    
    # Adapt sleep interval depending on active usage to save CPU/Battery
    if [ "$aider_running" -eq 1 ]; then
        sleep 0.2
    else
        sleep 1.0
    fi
done
