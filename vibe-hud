#!/bin/bash

# Colors for terminal output
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
GRAY='\033[0;90m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Clear screen initially
clear

# Hide cursor
tput civis

# Flag to track if the static ASCII header has been drawn
header_drawn=0

# Variables for pure Bash CPU calculation
prev_idle=0
prev_total=0

# Restore cursor on exit
trap 'tput cnorm; exit' INT TERM EXIT

# Trap window resize signals to force a header redraw
trap 'clear; header_drawn=0' WINCH

draw_static_header() {
    cols=$(tput cols)
    border=$(printf -- '=%.0s' $(seq 1 $cols))
    
    tput cup 0 0
    echo -e "${CYAN}$border${NC}"
    echo -e "${CYAN} __     ___ _            _   _ _   _ ____   ${NC}"
    echo -e "${CYAN} \\ \\   / (_) |__   ___  | | | | | | |  _ \\  ${NC}"
    echo -e "${CYAN}  \\ \\ / /| | '_ \\ / _ \\ | |_| | | | | | | | ${NC}"
    echo -e "${CYAN}   \\ V / | | |_) |  __/ |  _  | |_| | |_| | ${NC}"
    echo -e "${CYAN}    \\_/  |_|_.__/ \\___| |_| |_|\\___/|____/  ${NC}"
    echo -e "${CYAN}$border${NC}"
    header_drawn=1
}

while true; do
    # 1. Draw static header only if not already drawn (or resized)
    if [ "$header_drawn" -eq 0 ]; then
        draw_static_header
    fi

    # Fetch terminal dimensions
    cols=$(tput cols)
    lines=$(tput lines)
    divider=$(printf -- '-%.0s' $(seq 1 $cols))
    border=$(printf -- '=%.0s' $(seq 1 $cols))

    # Fetch active models
    models_output=$(ollama ps 2>/dev/null | tail -n +2)

    # 2. Move cursor directly to Line 9 (0-indexed line 8) below the ASCII art
    tput cup 8 0

    # 3. Print Dynamic Info (Time & Shell)
    current_time=$(date +"%Y-%m-%d %H:%M:%S")
    echo -e "  ${CYAN}[ SYSTEM TIME ]${NC}  $current_time"
    echo -e "  ${CYAN}[ HOST SHELL  ]${NC}  $SHELL"
    echo -e "${GRAY}$divider${NC}"
    echo ""

    # 4. Fetch and Print Live Hardware Telemetry
    # A. NVIDIA GPU & VRAM Status
    gpu_info=$(nvidia-smi --query-gpu=memory.used,memory.total,utilization.gpu,temperature.gpu --format=csv,noheader,nounits 2>/dev/null)
    if [ -n "$gpu_info" ]; then
        gpu_used=$(echo "$gpu_info" | awk -F', ' '{print $1}')
        gpu_total=$(echo "$gpu_info" | awk -F', ' '{print $2}')
        gpu_load=$(echo "$gpu_info" | awk -F', ' '{print $3}')
        gpu_temp=$(echo "$gpu_info" | awk -F', ' '{print $4}')

        # Floating point calculations in pure Bash
        used_gb_val=$(( gpu_used / 1024 ))
        used_mb_val=$(( (gpu_used % 1024) * 10 / 1024 ))
        gpu_used_gb="${used_gb_val}.${used_mb_val}"

        total_gb_val=$(( gpu_total / 1024 ))
        total_mb_val=$(( (gpu_total % 1024) * 10 / 1024 ))
        gpu_total_gb="${total_gb_val}.${total_mb_val}"

        gpu_pct=$(( gpu_used * 100 / gpu_total ))

        # Create VRAM Progress Bar
        bar_width=12
        filled=$(( gpu_pct * bar_width / 100 ))
        empty=$(( bar_width - filled ))
        
        if [ "$filled" -gt 0 ]; then
            bar_filled=$(printf -- '█%.0s' $(seq 1 $filled))
        else
            bar_filled=""
        fi
        if [ "$empty" -gt 0 ]; then
            bar_empty=$(printf -- '░%.0s' $(seq 1 $empty))
        else
            bar_empty=""
        fi
    else
        gpu_used_gb="N/A"
        gpu_total_gb="N/A"
        gpu_pct=0
        gpu_load="N/A"
        gpu_temp="N/A"
        bar_filled=""
        bar_empty="░░░░░░░░░░░░"
    fi

    # B. Pure Bash CPU Utilization Calculator (reads ticks since last 0.2s loop)
    read -r _ user nice system idle iowait irq softirq steal guest guest_nice < /proc/stat
    total_ticks=$((user + nice + system + idle + iowait + irq + softirq + steal))
    idle_ticks=$idle

    diff_total=$((total_ticks - prev_total))
    diff_idle=$((idle_ticks - prev_idle))

    if [ "$diff_total" -gt 0 ]; then
        cpu_usage=$(( (diff_total - diff_idle) * 100 / diff_total ))
    else
        cpu_usage=0
    fi

    prev_total=$total_ticks
    prev_idle=$idle_ticks

    # Create CPU Progress Bar
    cpu_bar_width=12
    cpu_filled=$(( cpu_usage * cpu_bar_width / 100 ))
    cpu_empty=$(( cpu_bar_width - cpu_filled ))
    
    if [ "$cpu_filled" -gt 0 ]; then
        cpu_bar_filled=$(printf -- '█%.0s' $(seq 1 $cpu_filled))
    else
        cpu_bar_filled=""
    fi
    if [ "$cpu_empty" -gt 0 ]; then
        cpu_bar_empty=$(printf -- '░%.0s' $(seq 1 $cpu_empty))
    else
        cpu_bar_empty=""
    fi

    # C. Fetch System RAM usage
    ram_info=$(free -m | awk '/Mem:/ {printf "%.1f GB / %.1f GB (%.0f%%)\n", $3/1024, $2/1024, $3/$2*100}')

    echo -e "  ${CYAN}[ HARDWARE STATUS ]${NC}"
    echo -e "  VRAM Usage:   [${GREEN}${bar_filled}${GRAY}${bar_empty}${NC}] ${gpu_used_gb} GB / ${gpu_total_gb} GB (${gpu_pct}%)"
    echo -e "  GPU Load/Temp: ${YELLOW}${gpu_load}% Load${NC} | ${YELLOW}${gpu_temp}°C${NC}"
    echo -e "  CPU Usage:    [${GREEN}${cpu_bar_filled}${GRAY}${cpu_bar_empty}${NC}] ${cpu_usage}% Load"
    echo -e "  System RAM:    $ram_info"
    echo -e "${GRAY}$divider${NC}"
    echo ""

    # 5. Dynamic Aider Dual-Model Status Card
    # Read currently configured model names from global Aider config
    config_file="$HOME/.aider.conf.yml"
    main_model="qwen3-coder:30b-tweaked"
    editor_model="qwen2.5-coder:7b"

    if [ -f "$config_file" ]; then
        main_model_line=$(grep "^model:" "$config_file" | awk '{print $2}')
        if [ -n "$main_model_line" ]; then
            main_model=${main_model_line##*/}
        fi
        editor_model_line=$(grep "^editor-model:" "$config_file" | awk '{print $2}')
        if [ -n "$editor_model_line" ]; then
            editor_model=${editor_model_line##*/}
        fi
    fi

    # Determine status of each model in VRAM
    arch_active=0
    edit_active=0
    
    if echo "$models_output" | grep -q "$main_model"; then
        arch_active=1
    fi
    if echo "$models_output" | grep -q "$editor_model"; then
        edit_active=1
    fi

    # Handle fallbacks if a larger family model is currently loading
    if [ "$arch_active" -eq 0 ] && [ "$edit_active" -eq 0 ] && [ -n "$models_output" ]; then
        if echo "$models_output" | grep -q -E "30b|next"; then
            arch_active=1
        else
            edit_active=1
        fi
    fi

    # Resolve status tags
    if [ "$arch_active" -eq 1 ] && [ "$edit_active" -eq 1 ]; then
        arch_status="${BLUE}[ ACTIVE ]${NC}"
        edit_status="${GREEN}[ ACTIVE ]${NC}"
    elif [ "$arch_active" -eq 1 ] && [ "$edit_active" -eq 0 ]; then
        arch_status="${BLUE}[ ACTIVE ]${NC} ◀ Processing Plan"
        edit_status="${YELLOW}[ PENDING ]${NC}  Switching next..."
    elif [ "$arch_active" -eq 0 ] && [ "$edit_active" -eq 1 ]; then
        arch_status="${GRAY}[  IDLE  ]${NC}"
        edit_status="${GREEN}[ ACTIVE ]${NC} ◀ Applying Edits"
    else
        arch_status="${GRAY}[  IDLE  ]${NC}"
        edit_status="${GRAY}[  IDLE  ]${NC}"
    fi

    echo -e "  ${CYAN}[ OLLAMA DUAL-MODEL STATUS ]${NC}"
    printf "  %-12s  %-30s  %-25s\n" "MAIN ROLE" "MODEL NAME" "STATUS / VRAM STATE"
    printf "  %-12s  %-30s  %-25s\n" "---------" "----------" "-------------------"
    printf "  %-12s  %-30s  %-25s\n" "Architect" "$main_model" "$arch_status"
    printf "  %-12s  %-30s  %-25s\n" "Editor"    "$editor_model" "$edit_status"
    echo ""
    echo -e "${CYAN}$border${NC}"
    echo -e "  Press [Ctrl+C] to exit HUD.                       "
    
    # Silently clear the rest of the screen below the HUD
    tput ed
    
    sleep 0.2
done
