#!/bin/bash
# vibe-start - Start Aider and vibe-hud side-by-side in Tmux

# Check if tmux is installed
if ! command -v tmux &> /dev/null; then
    echo -e "\e[0;31mError: 'tmux' is not installed!\e[0m"
    echo -e "To launch side-by-side splits, please install tmux first."
    echo -e "On Arch / CachyOS: \e[0;32msudo pacman -S tmux\e[0m"
    exit 1
fi
# If a directory argument is provided, change to that directory first to make the entire workspace target it
if [ -n "$1" ]; then
    if [ -d "$1" ]; then
        cd "$1" || exit 1
    else
        echo -e "\e[0;31mError: Directory '$1' does not exist!\e[0m"
        exit 1
    fi
fi
# Check if session already exists to prevent duplicate splits and double-run commands
if tmux has-session -t vibe-coding 2>/dev/null; then
    echo -e "\e[0;33mSession 'vibe-coding' is already running.\e[0m"
    if [ -n "$1" ]; then
        echo -e "\e[0;31mWarning: You specified a new directory '$1', but cannot switch while the session is active!\e[0m"
        echo -e "To switch to your new folder, please close the current session first:"
        echo -e "  👉 \e[0;32mtmux kill-session -t vibe-coding\e[0m"
        echo -e "  👉 Then run your command again!"
        exit 1
    fi
    echo -e "Attaching to the existing session..."
    sleep 1
    tmux attach-session -t vibe-coding
    exit 0
fi

# Create a new tmux session named 'vibe-coding' running Aider as the primary process
tmux new-session -d -s vibe-coding -n 'Vibe Workspace' 'aider'

# Split the workspace horizontally and run 'vibe-hud' in the right pane (35% width)
tmux split-window -h -p 35 -t vibe-coding "$HOME/.local/bin/vibe-hud"

# Split the entire window vertically from the bottom and run 'vibe-asset-monitor' (30% height, full-width)
tmux split-window -v -f -p 30 -t vibe-coding "$HOME/.local/bin/vibe-asset-monitor"

# Select the main coding pane (Aider) as active by default
tmux select-pane -t vibe-coding:0.0

# Attach to the tmux session
tmux attach-session -t vibe-coding
