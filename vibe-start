#!/bin/bash
# vibe-start - Start Aider and vibe-hud side-by-side in Tmux

# CHANGELOG:
# - Now gracefully kills existing vibe-coding sessions before starting
# - Executes vibe-free immediately after session kill to flush VRAM

# Check if tmux is installed
if ! command -v tmux &> /dev/null; then
    echo -e "\e[0;31mError: 'tmux' is not installed!\e[0m"
    echo -e "To launch side-by-side splits, please install tmux first."
    echo -e "On Arch / CachyOS: \e[0;32msudo pacman -S tmux\e[0m"
    exit 1
fi
# Parse arguments dynamically
target_dir=""
mode="default"
profile=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        deepseek|translate|qwen|uncensored)
            mode="$1"
            shift
            ;;
        gamedev|general)
            profile="$1"
            shift
            ;;
        *)
            if [ -d "$1" ]; then
                target_dir="$1"
            else
                echo -e "\e[0;31mError: Directory, mode, or profile '$1' is invalid!\e[0m"
                echo -e "Usage: vibe-start [dir] [qwen|deepseek|translate|uncensored] [gamedev|general]"
                exit 1
            fi
            shift
            ;;
    esac
done

if [ -n "$target_dir" ]; then
    cd "$target_dir" || exit 1
fi

# Auto-detect and purge accidental zero-byte untracked files created by Aider
if git rev-parse --is-inside-work-tree &>/dev/null; then
    untracked_files=$(git status --porcelain | grep "^??" | cut -c4-)
    if [ -n "$untracked_files" ]; then
        echo "$untracked_files" | while read -r file; do
            file_clean=$(echo "$file" | sed -e 's/^"//' -e 's/"$//')
            if [ -f "$file_clean" ] && [ ! -s "$file_clean" ]; then
                filename=$(basename "$file_clean")
                if [[ "$filename" != ".gitignore" && "$filename" != ".gitattributes" && "$filename" != ".editorconfig" ]]; then
                    echo -e "\e[0;33m[VIBE] Auto-purged accidental zero-byte file: '$file_clean'\e[0m"
                    rm -f "$file_clean"
                fi
            fi
        done
    fi
fi

# Auto-stage untracked or renamed files so Aider's RepoMap is always 100% complete
if git rev-parse --is-inside-work-tree &>/dev/null; then
    echo -e "\e[0;32m[VIBE] Staging untracked & renamed files to Git for RepoMap consistency...\e[0m"
    git add .
fi

# Check if session already exists, and kill it to ensure a fresh start
if tmux has-session -t vibe-coding 2>/dev/null; then
    echo -e "\e[0;33mClosing existing 'vibe-coding' session...\e[0m"
    tmux kill-session -t vibe-coding
    sleep 1
fi

# Ensure all background AI models are unloaded before starting
if command -v vibe-free &> /dev/null; then
    vibe-free
fi

# Print active working directory
echo -e "\e[0;34mActive Workspace Directory: \e[1;36m$(pwd)\e[0m"

# Setup instruction profiles if specified
if [ "$profile" = "gamedev" ]; then
    echo -e "\e[0;32m[VIBE] Loading Game Developer custom instructions (Godot & GameMaker)...\e[0m"
    cp "$HOME/Documents/GitHub/vibe-coding-setup/prompts/game-dev.instructions.md" "./.aider.instructions.md"
elif [ "$profile" = "general" ]; then
    echo -e "\e[0;32m[VIBE] Loading Professional Software Engineer custom instructions...\e[0m"
    cp "$HOME/Documents/GitHub/vibe-coding-setup/prompts/general-dev.instructions.md" "./.aider.instructions.md"
else
    # Clean up only if the existing file matches one of our templates to preserve user custom instructions
    if [ -f "./.aider.instructions.md" ]; then
        if diff -q "./.aider.instructions.md" "$HOME/Documents/GitHub/vibe-coding-setup/prompts/game-dev.instructions.md" &>/dev/null || \
           diff -q "./.aider.instructions.md" "$HOME/Documents/GitHub/vibe-coding-setup/prompts/general-dev.instructions.md" &>/dev/null; then
            echo -e "\e[0;33m[VIBE] Cleaning up previous profile instructions...\e[0m"
            rm -f "./.aider.instructions.md"
        fi
    fi
fi

# Determine Aider command based on mode
case "$mode" in
    deepseek)
        echo -e "\e[0;32mStarting Vibe Workspace with DeepSeek Coder V2 16B (General Coding)...\e[0m"
        aider_cmd="aider --model ollama_chat/deepseek-coder-v2:16b-tweaked --edit-format diff"
        ;;
    translate)
        echo -e "\e[0;32mStarting Vibe Workspace with DeepSeek Coder V2 16B (Code Translation Profile)...\e[0m"
        aider_cmd="aider --model ollama_chat/deepseek-coder-v2:16b-translate --edit-format diff"
        ;;
    uncensored)
        echo -e "\e[0;32mStarting Uncensored Vibe Workspace with Dolphin Llama 3 8B (Unrestricted Profile)...\e[0m"
        aider_cmd="aider --model ollama_chat/dolphin-llama3:8b-tweaked --edit-format diff"
        ;;
    *)
        echo -e "\e[0;32mStarting Vibe Workspace with default Qwen 30B/7B Dual-Model (Architect Mode)...\e[0m"
        aider_cmd="aider"
        ;;
esac

# Create a new tmux session named 'vibe-coding' running Aider as the primary process
tmux new-session -d -s vibe-coding -n 'Vibe Workspace' "$aider_cmd"

# Split the workspace horizontally and run 'vibe-hud' in the right pane (35% width)
tmux split-window -h -p 35 -t vibe-coding "$HOME/.local/bin/vibe-hud"

# Split the left pane vertically to run 'vibe-asset-menu' in the bottom-left pane
tmux split-window -v -p 30 -t vibe-coding:0.0 "$HOME/.local/bin/vibe-asset-menu"

# Split the right pane vertically to run the cycling 'vibe-commands' cheatsheet in the bottom-right pane
tmux split-window -v -p 30 -t vibe-coding:0.1 "$HOME/.local/bin/vibe-commands"

# Select the main coding pane (Aider) as active by default
tmux select-pane -t vibe-coding:0.0

# Attach to the tmux session
tmux attach-session -t vibe-coding
