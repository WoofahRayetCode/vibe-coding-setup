#!/bin/bash
# vibe-start - Start Aider and vibe-hud side-by-side in Tmux

# Check if tmux is installed
if ! command -v tmux &> /dev/null; then
    echo -e "\e[0;31mError: 'tmux' is not installed!\e[0m"
    echo -e "To launch side-by-side splits, please install tmux first."
    echo -e "On Arch / CachyOS: \e[0;32msudo pacman -S tmux\e[0m"
    exit 1
fi

# Check if session already exists to prevent duplicate splits and double-run commands
if tmux has-session -t vibe-coding 2>/dev/null; then
    echo -e "\e[0;33mSession 'vibe-coding' is already running.\e[0m"
    echo -e "Attaching to the existing session..."
    sleep 1
    tmux attach-session -t vibe-coding
    exit 0
fi

# Create a new tmux session named 'vibe-coding'
tmux new-session -d -s vibe-coding

# Rename first window
tmux rename-window -t vibe-coding 'Vibe Workspace'

# Split the workspace horizontally (creates top-left and top-right panes)
# Top-Left gets 65% width (for Aider), Top-Right gets 35% width (for vibe-hud)
tmux split-window -h -p 35 -t vibe-coding

# Split the entire window vertically from the bottom (full-width bottom pane)
# Bottom pane gets 30% height of the total terminal frame
tmux split-window -v -f -p 30 -t vibe-coding

# Route commands explicitly to their designated pane indices for absolute reliability
# Pane 0.0: Top-Left (Aider)
tmux send-keys -t vibe-coding:0.0 'aider' C-m

# Pane 0.1: Top-Right (vibe-hud)
tmux send-keys -t vibe-coding:0.1 'vibe-hud' C-m

# Pane 0.2: Bottom Full-Width (ComfyUI / Asset Watcher)
tmux send-keys -t vibe-coding:0.2 'if ! curl -s http://127.0.0.1:8188/ &> /dev/null; then cd /home/ericparsley/Documents/GitHub/ComfyUI && ./venv/bin/python main.py; else echo "ComfyUI Server is already running!"; echo "Monitoring generated PNG assets..."; watch -n 1 -d "ls -la --color=always *.png 2>/dev/null"; fi' C-m

# Select the main coding pane (Aider) as active by default
tmux select-pane -t vibe-coding:0.0

# Attach to the tmux session
tmux attach-session -t vibe-coding
